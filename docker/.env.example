############################################################
# Simply Imóveis - Configuração Docker (self-hosted)
# Copie para .env e ajuste os valores antes de subir.
############################################################

# ========== DOMÍNIO ==========
SITE_DOMAIN="simplyimoveis.com.br"

# ========== BANCO ==========
POSTGRES_USER="supabase_admin"
POSTGRES_PASSWORD="SuaSenhaForteAqui123!"
POSTGRES_DB="simply_db"

# ========== JWT / API KEYS ==========
# Se usar install.sh, estes valores são gerados automaticamente.
JWT_SECRET="super-secret-jwt-token-with-at-least-32-characters-long"
ANON_KEY="CHANGE_ME"
SERVICE_ROLE_KEY="CHANGE_ME"

# ========== SMTP (confirmação de email) ==========
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_SENDER_NAME="Simply Imóveis"
SMTP_ADMIN_EMAIL="admin@simplyimoveis.com.br"

# ========== CHAT IA ==========
GROQ_API_KEY="gsk_XXXXXXXXXXXXXXXXXXXX"

# ========== TELEGRAM (opcional) ==========
# Opção A: Conector (TELEGRAM_API_KEY + LOVABLE_API_KEY)
# Opção B: Bot direto (TELEGRAM_BOT_TOKEN)
LOVABLE_API_KEY=""
TELEGRAM_API_KEY=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ========== PORTAS ==========
KONG_HTTP_PORT="8000"
FRONTEND_PORT="3000"
