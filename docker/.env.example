############################################################
# Simply Imóveis - Configuração Docker
# Copie este arquivo para .env e preencha os valores
# IMPORTANTE: Valores com espaços DEVEM estar entre aspas
############################################################

# ========== DOMÍNIO ==========
SITE_DOMAIN="simplyimoveis.com.br"

# ========== SENHAS DO BANCO ==========
POSTGRES_PASSWORD="SuaSenhaForteAqui123!"
POSTGRES_DB="simply_db"

# ========== SUPABASE ==========
# Gerado automaticamente pelo install.sh
JWT_SECRET="super-secret-jwt-token-with-at-least-32-characters-long"

# Geradas automaticamente pelo generate-keys.sh
ANON_KEY="CHANGE_ME"
SERVICE_ROLE_KEY="CHANGE_ME"

# ========== SMTP (para confirmação de email) ==========
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_SENDER_NAME="Simply Imóveis"
SMTP_ADMIN_EMAIL="admin@simplyimoveis.com.br"

# ========== GROQ API (Chat Luma) ==========
GROQ_API_KEY="gsk_XXXXXXXXXXXXXXXXXXXX"

# ========== TELEGRAM (Notificações) ==========
# Opção A (connector/Lovable): TELEGRAM_API_KEY
# Opção B (bot direto): TELEGRAM_BOT_TOKEN
TELEGRAM_API_KEY=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ========== PORTAS INTERNAS (ajuste se conflitar) ==========
KONG_HTTP_PORT="8000"
FRONTEND_PORT="3000"
STUDIO_PORT="3001"
