############################################################
# Simply Imóveis - Configuração Docker (self-hosted)
# Copie para .env e ajuste os valores antes de subir.
# Gerado automaticamente pelo install.sh quando possível.
############################################################

# ========== DOMÍNIO ==========
# (obrigatório) Domínio principal do site
SITE_DOMAIN="simplyimoveis.com.br"

# ========== BANCO DE DADOS ==========
# (obrigatório) Credenciais PostgreSQL - geradas automaticamente pelo install.sh
POSTGRES_USER="supabase_admin"
POSTGRES_PASSWORD="SuaSenhaForteAqui123!"
POSTGRES_DB="simply_db"

# ========== JWT / API KEYS ==========
# (obrigatório) Gerados automaticamente pelo install.sh
JWT_SECRET="super-secret-jwt-token-with-at-least-32-characters-long"
ANON_KEY="CHANGE_ME"
SERVICE_ROLE_KEY="CHANGE_ME"

# ========== SMTP (confirmação de email) ==========
# (obrigatório para confirmação de email e recuperação de senha)
# Para Gmail: use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_SENDER_NAME="Simply Imóveis"
SMTP_ADMIN_EMAIL="admin@simplyimoveis.com.br"

# ========== CHAT IA (Groq) ==========
# (obrigatório para o chat IA funcionar)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY="gsk_XXXXXXXXXXXXXXXXXXXX"

# ========== TELEGRAM (opcional) ==========
# Para notificações de visitas agendadas via Telegram
#
# Como configurar:
# 1. Crie um bot via @BotFather no Telegram
# 2. Copie o token do bot para TELEGRAM_BOT_TOKEN
# 3. Envie uma mensagem qualquer para o bot
# 4. Acesse: https://api.telegram.org/bot<SEU_TOKEN>/getUpdates
# 5. Copie o chat_id da resposta para TELEGRAM_CHAT_ID
#
# Opção A: Bot direto (recomendado para self-hosted)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
#
# Opção B: Via Lovable Connector (apenas no Lovable Cloud)
LOVABLE_API_KEY=""
TELEGRAM_API_KEY=""

# ========== PORTAS ==========
# (opcional) Portas locais dos serviços
# Kong (API Gateway): acesso interno em 127.0.0.1 apenas
# Frontend: acesso interno em 127.0.0.1 apenas
# Use Nginx como reverse proxy para expor ao público
KONG_HTTP_PORT="8000"
FRONTEND_PORT="3000"
