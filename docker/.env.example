############################################################
# Simply Imóveis - Configuração Docker
# Copie este arquivo para .env e preencha os valores
############################################################

# ========== DOMÍNIO ==========
SITE_DOMAIN=simplyimoveis.com.br

# ========== SENHAS DO BANCO ==========
POSTGRES_PASSWORD=SuaSenhaForteAqui123!
POSTGRES_DB=simply_db

# ========== SUPABASE ==========
# Gere com: openssl rand -base64 32
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Gere com: node -e "console.log(require('jsonwebtoken').sign({ref:'simply',role:'anon',iss:'supabase',iat:Math.floor(Date.now()/1000),exp:Math.floor(Date.now()/1000)+315360000},process.env.JWT_SECRET||'super-secret-jwt-token-with-at-least-32-characters-long'))"
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGE_ME
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGE_ME

# ========== SMTP (para confirmação de email) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_SENDER_NAME=Simply Imóveis
SMTP_ADMIN_EMAIL=admin@simplyimoveis.com.br

# ========== GROQ API (Chat Luma) ==========
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXX

# ========== TELEGRAM (Notificações) ==========
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ========== PORTAS INTERNAS (ajuste se conflitar) ==========
KONG_HTTP_PORT=8000
FRONTEND_PORT=3000
STUDIO_PORT=3001
