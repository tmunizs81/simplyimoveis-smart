############################################################
# Simply Imóveis - Mínimo para Edge Functions (self-hosted)
# NÃO é necessário editar — o docker-compose.yml injeta
# automaticamente do .env principal.
############################################################

# Runtime / Auth (injetado pelo compose)
JWT_SECRET="jwt-secret-com-32-ou-mais-caracteres"
SUPABASE_URL="http://kong:8000"
SUPABASE_ANON_KEY="CHANGE_ME"
SUPABASE_SERVICE_ROLE_KEY="CHANGE_ME"

# Chat IA (obrigatório para /functions/v1/chat)
GROQ_API_KEY="gsk_XXXXXXXXXXXXXXXXXXXX"

# Telegram (opcional)
TELEGRAM_CHAT_ID=""
TELEGRAM_BOT_TOKEN=""
